# PulseMarket Agent — Environment Variables
# Copy this to .env and fill in the values

# Oracle wallet mnemonic (used to sign close_market + resolve_market transactions)
ORACLE_MNEMONIC=your_oracle_mnemonic_here

# Gemini API key (get one at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Shared secret for admin-only API routes
# Must match VITE_AGENT_SECRET in pulsemarket-frontend/.env
ADMIN_SECRET=change_me_to_a_random_secret

# Chain config (must match pulsemarket-frontend/.env)
CHAIN_ID=micro-markets
LCD_URL=http://localhost:1317
TENDERMINT_RPC_URL=http://localhost:26657
MODULE_ADDRESS=init1rrlffyalu47cwryh0lswluq8wuzktpdhzqvdwq
MODULE_NAME=pulse_market
FEE_DENOM=umin

# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
