# PulseMarket Agent — Environment Variables
# Copy this to .env and fill in the values

# Oracle wallet mnemonic (used to sign close_market + resolve_market transactions)
ORACLE_MNEMONIC=

# Gemini API key (get one at https://aistudio.google.com)
GEMINI_API_KEY=

# Gemini model id (default: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# Validation constraints for create-market AI gate
# Minimum seconds from now to close time
MARKET_MIN_CLOSE_LEAD_SECONDS=30
# Maximum days from now to resolve time (beyond this, create is rejected)
MARKET_MAX_RESOLUTION_FUTURE_DAYS=365

# Optional: include stack traces in structured error logs
LOG_ERROR_STACK=false

# Shared secret for admin-only API routes
# Must match VITE_AGENT_SECRET in pulsemarket-frontend/.env
ADMIN_SECRET=

# Chain config (must match pulsemarket-frontend/.env)
CHAIN_ID=micro-markets
LCD_URL=http://localhost:1317
TENDERMINT_RPC_URL=http://localhost:26657
MODULE_ADDRESS=init1rrlffyalu47cwryh0lswluq8wuzktpdhzqvdwq
MODULE_NAME=pulse_market
FEE_DENOM=umin

# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Derivation coin type for gas-station key from weave config (usually 60)
ORACLE_COIN_TYPE=60

# Use Ethereum derivation path mode for Initia gas-station mnemonic (usually true)
ORACLE_ETH_DERIVATION=true
