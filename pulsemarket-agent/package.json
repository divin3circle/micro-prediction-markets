{
  "name": "pulsemarket-agent",
  "version": "1.0.0",
  "description": "PulseMarket backend agent — auto-closes markets, AI research, oracle resolution",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --experimental-specifier-resolution=node --import ./cjs-loader.mjs src/server.js",
    "dev": "node --experimental-specifier-resolution=node --import ./cjs-loader.mjs --watch src/server.js",
    "rerun:research": "node --experimental-specifier-resolution=node --import ./cjs-loader.mjs scripts/rerun_research.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@initia/initia.js": "^0.2.28",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eventsource": "^4.1.0",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "secp256k1": "^5.0.1"
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
